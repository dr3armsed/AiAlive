[flake8]
max-line-length = 127
exclude =
    .git,
    node_modules,
    archive,
    artifacts,
    docs/architecture,
    scripts/python,
    data
extend-ignore =
    E231,
    E261,
    E302,
    E303,
    E305,
    E306,
    E401,
    E402,
    E501,
    E701,
    E702,
    E741,
    W291,
    W292,
    C901,
    F401,
    F541,
    F811,
    F841

select = E9,F63,F7,F82
