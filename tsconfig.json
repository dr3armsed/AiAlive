{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src/App.tsx",
    "src/main.tsx",
    "src/entry/**/*.ts",
    "src/entry/**/*.tsx",
    "src/runtime/**/*.ts",
    "src/runtime/**/*.tsx",
    "src/legacy/EmotionMeter.tsx",
    "vite.config.ts"
  ],
  "exclude": [
    "archive",
    "artifacts",
    "data",
    "docs",
    "scripts",
    "test",
    "tests",
    "**/*-1.ts",
    "**/*-1.tsx"
  ]
}
